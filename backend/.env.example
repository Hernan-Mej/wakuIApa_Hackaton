APP_NAME="Hackaton API"
APP_VERSION="0.1.0"
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# MySQL
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/hackaton?charset=utf8mb4
DATABASE_ECHO=false

# JWT auth — change in production!
JWT_SECRET=change-me-in-production-please-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Redis (optional cache for NASA POWER)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# LM Studio (OpenAI-compatible local server)
LMSTUDIO_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=qwen/qwen3-vl-4b
LMSTUDIO_TIMEOUT=180
LMSTUDIO_MAX_TOKENS=2500
LMSTUDIO_TEMPERATURE=0.6

# Chat
CHAT_HISTORY_WINDOW=20
